<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.AboutActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/about_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="4dp"
        android:background="?attr/colorPrimary"
        app:title="About"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_arrow_back"/>

    <ImageView
        android:id="@+id/about_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/about_toolbar"
        android:layout_marginTop="30dp"
        android:src="@mipmap/ic_launcher"/>

    <TextView
        android:id="@+id/about_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/about_logo"
        app:layout_constraintStart_toStartOf="@id/about_logo"
        app:layout_constraintEnd_toEndOf="@id/about_logo"
        android:layout_marginTop="10dp"
        android:text="version 1.0"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="20sp"/>

    <TextView
        android:id="@+id/about_app_developer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/about_app_name"
        app:layout_constraintStart_toStartOf="@id/about_logo"
        app:layout_constraintEnd_toEndOf="@id/about_logo"
        android:layout_marginTop="50dp"
        android:text="developer: Tomas Tu"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="20sp"/>

    <TextView
        android:id="@+id/about_app_logo_author"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/about_app_developer"
        app:layout_constraintStart_toStartOf="@id/about_logo"
        app:layout_constraintEnd_toEndOf="@id/about_logo"
        android:layout_marginTop="2dp"
        android:text="logo creator: Gao Cong"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="20sp"/>

    <TextView
        android:id="@+id/about_contact_me"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp"
        android:text="any issue? click here to contact me via email"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="15sp"/>
</androidx.constraintlayout.widget.ConstraintLayout>